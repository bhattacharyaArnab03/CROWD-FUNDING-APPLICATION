{
  "name": "crowdfunding-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "gateway": "node microservices/api-gateway/server.js",
    "user-service": "node microservices/user-service/server.js",
    "campaign-service": "node microservices/campaign-service/server.js",
    "payment-service": "node microservices/payment-service/server.js",
    "premicroservices": "npx kill-port 5000 5001 5002 5003 5173 || exit 0",
    "microservices": "concurrently \"npm run gateway\" \"npm run user-service\" \"npm run campaign-service\" \"npm run payment-service\" \"npm run dev\"",
    "start": "npm run microservices"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "mongoose": "^7.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "kill-port": "^2.0.1",
    "vite": "^5.0.0"
  }
}
